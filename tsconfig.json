{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "src/env.d.ts", "**/*"],
  "exclude": ["dist", "public", ".obsidian"],
  "compilerOptions": {
    "plugins": [
      { "name": "@astrojs/ts-plugin" },
    ],
    "paths": {
      "@components/*": ["./src/components/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@styles/*": ["./src/styles/*"],
      "@utils/*": ["./src/utils/*"],
      "@consts": ["./src/consts.ts"],
    },
    "verbatimModuleSyntax": true
  }
}

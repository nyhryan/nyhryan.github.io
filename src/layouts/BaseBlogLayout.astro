---
import "@styles/global.css";

import TopNavBar from "@components/layout/TopNavBar.astro";
import SideBar from "@components/layout/SideBar.astro";
import HomeBanner from "@components/layout/HomeBanner.astro";
import Footer from "@components/layout/Footer.astro";
import PaginationNav from "@components/common/PaginationNav.astro";
import type { Page } from "astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  currentCategory?: string;
  pages?: Page<CollectionEntry<"blog">>;
}

const { currentCategory, pages = null } = Astro.props;
---

<div class="min-h-screen text-ctp-text bg-ctp-crust flex flex-col">
  <div class="relative h-[10rem] sm:h-[25rem] w-full">
    <header class="sticky top-0 z-50 w-full">
      <div class="mx-auto max-w-5xl px-4">
        <TopNavBar />
      </div>
    </header>

    <div class="absolute inset-0 z-0 overflow-hidden">
      <HomeBanner />
    </div>
  </div>
  <div class="mx-auto max-w-5xl px-4 grid grid-rows-[auto_1fr] grid-cols-4 md:grid-cols-8 lg:grid-cols-24 gap-6 w-full py-8 grow">
    <aside
      class="col-span-4 md:col-span-8 lg:col-span-7 lg:h-fit lg:sticky lg:top-[5rem]"
    >
      <SideBar currentCategory={currentCategory} />
    </aside>
    <main class="col-span-4 md:col-span-8 lg:col-span-17 flex flex-col gap-y-6">
      <slot />
      <PaginationNav pages={pages} />
    </main>
  </div>
  <footer class="w-full mt-auto">
    <Footer />
  </footer>
</div>

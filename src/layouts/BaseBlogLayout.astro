---
import "@styles/global.css";

import type { ComponentProps } from "astro/types";
import WebSiteStructuredData from "@components/structuredData/WebSiteStructuredData.astro";
import TopNavBar from "@components/layout/TopNavBar.astro";
import Footer from "@components/layout/Footer.astro";
import HomeBanner from "@components/layout/HomeBanner.astro";
import SideBar from "@components/layout/SideBar.astro";
import BaseHead from "@components/layout/BaseHead.astro";
import Giscus from "@components/common/Giscus.astro";

type Props = {
  locale?: "en" | "ko";
} & ComponentProps<typeof BaseHead> & ComponentProps<typeof SideBar>;

const { locale, title, description, image, noindex, currentCategory, currentTag } = Astro.props;
---

<!doctype html>
<html lang={locale}>
  <head>
    <BaseHead title={title} description={description} image={image} noindex={noindex} />
    <slot name="structured-data">
      <WebSiteStructuredData />
    </slot>  
  </head>
  <body>
    <!-- Blog container -->
    <div class="flex min-h-screen flex-col text-ctp-text">
      <!-- Top nav bar + banner image -->
      <header class="relative h-[15rem] w-full sm:h-[30rem]">
        <!-- Top nav bar -->
        <div class="sticky top-0 z-50 w-full">
          <div class="mx-auto max-w-5xl px-2 sm:px-4">
            <TopNavBar />
          </div>
        </div>

        <!-- Banner image -->
        <div class="absolute inset-0 z-0 overflow-hidden">
          <HomeBanner />
        </div>
      </header>

      <!-- Sidebar + main -->
      <div
        class="mx-auto grid w-full max-w-5xl grow grid-cols-4 grid-rows-[auto_1fr] gap-4 px-2 py-8 sm:px-4 sm:grid-cols-8 lg:grid-cols-24"
      >
        <aside class="col-span-4 sm:col-span-8 lg:sticky lg:top-20 lg:col-span-7 lg:h-fit">
          <SideBar currentCategory={currentCategory} currentTag={currentTag} />
        </aside>

        <main class="col-span-4 sm:col-span-8 lg:col-span-17" id="main-swup-container">
          <slot name="main-content" />
          <slot name="after-main" />
          <Giscus />
        </main>
      </div>

      <!-- Footer -->
      <div class="mt-auto w-full">
        <Footer />
      </div>
    </div>
  </body>
</html>

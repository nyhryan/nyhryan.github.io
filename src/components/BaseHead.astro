---
import type { ImageMetadata } from "astro";
import { SEO } from "astro-seo";
import FallbackImage from "../assets/fallback.jpg";
import { SITE_TITLE, SITE_DESCRIPTION } from "@consts";
import Swup from "@components/common/Swup.astro";

type Props = {
  title?: string;
  description?: string;
  image?: ImageMetadata;
  noindex?: boolean;
};

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  image = FallbackImage,
  noindex = false,
} = Astro.props;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1.0" />
<link rel="icon" type="image/png" href="/favicon.png" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
  rel="alternate"
  type="application/rss+xml"
  title={title}
  href={new URL("rss.xml", Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Font preloads -->
<link
  rel="stylesheet"
  as="style"
  crossorigin
  href="https://unpkg.com/pretendard@1.3.9/dist/web/static/pretendard-dynamic-subset.css"
/>

<link
  rel="preload"
  href="/fonts/cascadia-code-v5-latin-regular.woff2"
  as="font"
  type="font/woff2"
  crossorigin
/>
<link
  rel="preload"
  href="/fonts/chiron-goround-tc-v4-latin-700.woff2"
  as="font"
  type="font/woff2"
  crossorigin
/>
<link
  rel="preload"
  href="/fonts/chiron-goround-tc-v4-latin-900.woff2"
  as="font"
  type="font/woff2"
  crossorigin
/>
<link
  rel="preload"
  href="/fonts/chiron-goround-tc-v4-latin-regular.woff2"
  as="font"
  type="font/woff2"
  crossorigin
/>

<SEO
  title={title}
  description={description}
  canonical={canonicalURL}
  openGraph={{
    basic: {
      title: title,
      type: "website",
      image: new URL(image.src, Astro.url).toString(),
      url: Astro.url,
    },
  }}
  twitter={{
    card: "summary_large_image",
    site: "@Rhy_Chang_Life",
    title: title,
    description: description,
    image: new URL(image.src, Astro.url),
    imageAlt: "Ataidev blog",
  }}
  noindex={noindex}
/>

<Swup />

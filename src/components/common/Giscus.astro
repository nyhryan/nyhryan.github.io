---
const paths = Astro.url.pathname.split("/");
const isPost = paths[1] === "blog";
---

<div class="giscus">
  { isPost && (
    <script is:inline
        src="https://giscus.app/client.js"
        data-repo="nyhryan/nyhryan.github.io"
        data-repo-id="R_kgDOPpedIQ"
        data-category="General"
        data-category-id="DIC_kwDOPpedIc4CvCAo"
        data-mapping="pathname"
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="bottom"
        data-theme="catppuccin_latte"
        data-lang="en"
        crossorigin="anonymous"
        async>
    </script>
  )}
</div>

<script>
  import { bindSwupHook } from "@utils/swup";
  import { initGiscusThemeSync } from "@utils/themeManager";
  
  bindSwupHook("page:view", initGiscusThemeSync);
</script>

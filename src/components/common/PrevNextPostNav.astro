---
import type { BlogPost } from "@utils/types";

type Props = {
  prev: BlogPost | null;
  next: BlogPost | null;
};

const { prev, next } = Astro.props;
---

<nav class="flex w-full flex-col gap-4 pb-4 sm:flex-row sm:justify-between" aria-label="Navigate post">
  <!-- Next post -->
  {
    <div
      class:list={[
        "relative grid min-h-24 w-full flex-1 grid-rows-[1fr_auto_auto] rounded-(--card-radius) p-4 shadow-sm/40",
        { "cursor-pointer bg-ctp-base": next },
        { "bg-ctp-mantle cursor-default": !next },
      ]}>
      <strong class:list={["text-left text-xl", { "text-ctp-surface0": !next }]}>Next</strong>
      {next && (
        <Fragment>
          <a class="mt-auto text-left" href={`/blog/${next.id}`}>
            <p class="overflow-hidden text-nowrap text-ellipsis">{next.data.title}</p>
          </a>
          <p class="text-left text-sm/5 text-ctp-subtext0">
            <time datetime={next.data.pubDate.toISOString()}>
              {next.data.pubDate.toLocaleDateString()}
            </time>
          </p>
        </Fragment>
      )}
    </div>
  }

  <!-- Previous Post -->
  {
    <div
      class:list={[
        "relative grid min-h-24 w-full flex-1 grid-rows-[1fr_auto_auto] rounded-(--card-radius) p-4 shadow-sm/40",
        { "cursor-pointer bg-ctp-base": prev },
        { "cursor-default border-ctp-surface0": !prev },
      ]}>
      <strong class:list={["text-right text-xl", { "text-ctp-surface0": !prev }]}>Previous</strong>
      {prev && (
        <Fragment>
          <a class="mt-auto text-right" href={`/blog/${prev.id}`}>
            <p class="overflow-hidden text-nowrap text-ellipsis">
              {prev.data.title}
            </p>
          </a>
          <p class="text-right text-sm/5 text-ctp-subtext0">
            <time datetime={prev.data.pubDate.toISOString()}>
              {prev.data.pubDate.toLocaleDateString()}
            </time>
          </p>
        </Fragment>
      )}
    </div>
  }
</nav>

<style>
  @reference "@styles/global.css";

  a {
    &::before {
      @apply absolute inset-0 z-1 cursor-pointer rounded-(--card-radius) outline-2 outline-transparent transition-[outline-color] duration-200 content-[""];
    }

    &:hover::before,
    &:focus-visible::before {
      @apply outline-(--color-primary);
    }

    &:hover,
    &:focus-visible {
      @apply outline-none;
    }
  }
</style>

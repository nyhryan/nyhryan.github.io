---
import type { CategoryNode } from "@/utils/categoryTree";

interface Props {
  node: CategoryNode;
  depth?: number;
  currentCategory?: string;
}

const { node, depth = 0, currentCategory: curr } = Astro.props;
const hasChildren = Object.keys(node.children).length > 0;
const isCurrent = curr === node.name;
---

<li class="cat-item relative">
  <div class="pl-[5px]">
    <a
      href={`/category/${node.fullPath}`}
      class:list={[
        "hover:decoration-ctp-lavender! hover:text-ctp-lavender! hover:underline!",
        {"text-ctp-lavender font-bold underline decoration-ctp-lavender": isCurrent},
        {"text-ctp-text font-normal no-underline": !isCurrent}
      ]}>
      <span class="relative z-3">
        <svg class:list={[
            "inline h-[16px] w-[16px]", 
            {"fill-ctp-lavender": isCurrent}, 
            {"fill-ctp-text": !isCurrent}
          ]}
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 16 16">
          <path d="M9.828 3h3.982a2 2 0 0 1 1.992 2.181l-.637 7A2 2 0 0 1 13.174 14H2.825a2 2 0 0 1-1.991-1.819l-.637-7a2 2 0 0 1 .342-1.31L.5 3a2 2 0 0 1 2-2h3.672a2 2 0 0 1 1.414.586l.828.828A2 2 0 0 0 9.828 3m-8.322.12q.322-.119.684-.12h5.396l-.707-.707A1 1 0 0 0 6.172 2H2.5a1 1 0 0 0-1 .981z" ></path>
        </svg>
      </span>
      {node.name} ({node.postCount})
    </a>
  </div>
</li>
{
  hasChildren && (
    <li class="cat-recursive-item relative">
      <ul class="flex flex-col pl-[15px]">
        {Object.values(node.children).map((child) => (
          <Astro.self node={child} depth={depth + 1} currentCategory={curr} />
        ))}
      </ul>
    </li>
  )
}

<style>
  @reference "@styles/global.css";

  .cat-item::before {
    @apply border-l-ctp-overlay2 border-b-ctp-overlay2 absolute -top-[9px] left-[-5px] z-1 h-full w-[15px] border-b-1 border-l-1;
    content: "";
  }

  li:not(.cat-item) {
    &::before {
      @apply border-l-ctp-overlay2 absolute -top-[9px] left-[-5px] z-1 h-full w-[15px] border-l-1;
      content: "";
    }
  }

  .cat-recursive-item .cat-recursive-item:not(.cat-item:last-child) {
    &::before {
      @apply absolute z-1 border-none;
      content: "";
    }
  }
</style>

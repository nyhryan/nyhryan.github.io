---
import { CalendarDays, Tag, Folder } from "@lucide/astro";
import type { CollectionEntry } from "astro:content";

type Props = CollectionEntry<"blog">;

const {
  id,
  data: { title, description, pubDate, tags },
} = Astro.props;
const category = id.split("/").slice(0, -1).join("/");
---

<article class="relative grid h-auto min-h-40 w-full grid-rows-[auto_1fr_auto] content-center gap-2 rounded-(--card-radius) bg-ctp-base font-chiron shadow-sm/40">
  <!-- Post title -->
  <header class="self-center overflow-hidden px-6 py-4">
    <a href={`/blog/${id}`} class="card-link block w-full">
      <h2 class="truncate text-3xl font-black">{title}</h2>
    </a>
  </header>

  <!-- Post description -->
  <div class="flex w-full flex-col gap-2 self-start justify-self-start px-6 pb-2 text-base/tight">
    <span>{description}</span>
  </div>

  <!-- Post metadata(pubdate, tags, category) -->
  <footer
    class="mt-auto flex w-full flex-row justify-start rounded-b-(--card-radius) border-t-2 border-dashed border-ctp-surface0 bg-ctp-surface0/30 px-6 py-3 text-sm"
    aria-label={`Article '${title}' metadata`}
  >
    <!-- Pub date -->
    <div class="flex items-center gap-1" aria-label="published date">
      <span class="sr-only">Published on</span>
      <CalendarDays class="size-4" />
      <time datetime={pubDate.toISOString()} class="text-nowrap">{pubDate.toLocaleDateString()}</time>
    </div>

    <!-- Tags -->
    <div class="relative z-2 hidden flex-row items-center gap-2 sm:flex" aria-label="tags">
      <Tag class="size-4"/>
      <ul 
        class="flex flex-row flex-wrap gap-1.5" 
        aria-label="tag list"
      >
        {
          tags.map((tag) => (
            <li>
              <a href={`/tag/${tag}/`} 
                class={`\
                min-w-[3ch] rounded-md bg-ctp-overlay0/10 px-2 py-0.5 ring ring-ctp-overlay0/80 transition-colors duration-200\
                hover:bg-(--color-primary)/10 hover:text-(--color-primary) hover:ring-2 hover:ring-(--color-primary)/40\
                `}
                title={`Filter posts of tag: ${tag}`}
              >{tag}</a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Category -->
    <div class="relative z-2 flex flex-row items-center gap-2" aria-label="category">
      <Folder class="size-4.5" />
      <a 
        href={`/category/${category}/`} 
        class="group flex flex-row items-center justify-center gap-1 border-b transition duration-200 hover:bg-(--color-secondary)/10 hover:text-(--color-secondary)"
        title={`Filter posts of category: ${category}`}
      >
        <span>{category}</span>
      </a>
    </div>
  </footer>
</article>

<style>
  @reference "@styles/global.css";

  footer > *:not(:last-child) {
    &::after {
      @apply content-[""] border-r-2 border-ctp-surface0 h-full mx-2;
    }
  }

  .card-link {
    &::before {
      @apply absolute inset-0 z-1 cursor-pointer rounded-(--card-radius) border-2 border-transparent transition-[border-color] duration-200 content-[""];
    }

    &:hover::before,
    &:focus::before {
      @apply border-(--color-primary);
    }

    &:focus {
      @apply outline-none;
    }
  }
</style>

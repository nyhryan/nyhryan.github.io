---
import { House, Menu, X } from "@lucide/astro";
import LightModeToggleButton from "@components/common/LightModeToggleButton.astro";

function isAriaCurrent(path: string) {
  if (path === Astro.url.pathname) return "page";
  else return undefined;
}
---

<nav
  id="primary-nav"
  aria-label="Primary nav"
  class="relative flex flex-row items-center justify-between gap-x-4 bg-(--color-background-light) p-3 transition-[border-radius] duration-100 sm:rounded-b-(--card-radius) sm:px-8 sm:py-2"
  x-bind:class="open ? 'rounded-b-0' : 'rounded-b-(--card-radius)'"
  x-data={`{
    open:false,
    toggle() {
      this.open = !this.open;
    }
  }`}
>
  <!-- Home button -->
  <a href="/" class="grid flex-1 sm:flex-none">
    <House class="size-8.5 text-(--color-text) transition duration-300 hover:scale-110 hover:-rotate-12 hover:text-(--color-primary)" />
    <span class="sr-only">Go to home</span>
  </a>

  <!-- Hidden hamburger toggle checkbox -->
  <button
    aria-controls="topnav-menu"
    class="relative cursor-pointer transition-all duration-200 ease-in-out select-none sm:hidden"
    x-bind:aria-expanded="open"
    x-bind:class="open ? 'rotate-90' : 'rotate-0'"
    x-on:click.debounce.100ms="toggle()"
  >
    <!-- Hamburger menu icon -->
    <div class="flex h-8 w-8 items-center justify-center" x-show="!open">
      <Menu class="text-(--color-text) size-8" />
      <span class="sr-only">Open navigation menu</span>
    </div>
    <!-- Close button -->
    <div class="flex h-8 w-8 items-center justify-center" x-show="open" x-cloak>
      <X class="text-(--color-text) size-8"/>
      <span class="sr-only">Close navigation menu</span>
    </div>
  </button>

  <!-- Menu(home, about) -->
  <div
    id="topnav-menu-mobile"
    class="absolute top-full left-0 -z-1 w-full rounded-b-(--card-radius) border-t border-t-ctp-surface0 bg-(--color-background-light) sm:static sm:z-auto sm:block! sm:w-auto sm:border-t-0"
    x-show="open"
    x-cloak
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="-translate-y-full"
    x-transition:enter-end="translate-y-0"
    x-transition:leave="transition ease-in duration-300"
    x-transition:leave-start="translate-y-0"
    x-transition:leave-end="-translate-y-full"
  >
    <ul class="text-2xl font-black sm:flex sm:flex-row sm:justify-center sm:gap-x-24 sm:text-3xl">
      <li class="sm:hover:underline-(--color-primary) p-2 transition-colors duration-200 hover:bg-(--color-item-hover) hover:text-(--color-primary) sm:hover:bg-transparent sm:hover:underline">
        <a href="/" aria-current={isAriaCurrent("/")} class="aria-[current='page']:underline">Home</a>
      </li>
      <li class="sm:hover:underline-(--color-primary) p-2 transition-colors duration-200 hover:bg-(--color-item-hover) hover:text-(--color-primary) sm:hover:bg-transparent sm:hover:underline">
        <a href="/about" aria-current={isAriaCurrent("/about")} class="aria-[current='page']:underline">About</a>
      </li>
    </ul>
  </div>

  <!-- Light mode toggle button -->
  <div class="grid h-8 w-8">
    <LightModeToggleButton />
  </div>
</nav>

---

import bannerImage from "../../assets/banner.jpg";
import { Image } from "astro:assets";
---

<>
  <Image class="object-top object-cover w-full h-full" src={bannerImage} alt="Blog banner" />
  <svg class="absolute bottom-0 left-0 right-0 w-full h-[75px] fill-ctp-mantle" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 24 150 28" preserveAspectRatio="none" shape-rendering="auto">
    <!-- Defining SVG element for waves -->
    <defs>
      <!-- Defining the wave path once to reuse it for creating multiple wave layers -->
      <path id="gentle-wave" d="M-160 44c30 0 58-18 88-18s 58 18 88 18 58-18 88-18 58 18 88 18 v44h-352z" />
    </defs>
    <g class="wave-parallax">
      <!-- Group of waves that will move at different speeds to create a parallax effect -->
      <use xlink:href="#gentle-wave" x="48" y="0" class="fill-ctp-crust/70" /> <!-- First wave layer -->
      <use xlink:href="#gentle-wave" x="48" y="3" class="fill-ctp-crust/50" /> <!-- Second wave layer -->
      <use xlink:href="#gentle-wave" x="48" y="5" class="fill-ctp-crust/30" /> <!-- Third wave layer -->
      <use xlink:href="#gentle-wave" x="48" y="7" class="fill-ctp-crust" /> <!-- Fourth wave layer -->
    </g>
  </svg>
</>

<style>
  @reference "@styles/global.css";

  /* https://codepen.io/PixelPerfectLabs/pen/PoMNONm */
  /* Animation for wave parallax */
  .wave-parallax > use {
    /* Infinite animation to move the waves */
    animation: move-forever 25s cubic-bezier(0.55, 0.5, 0.45, 0.5) infinite;
  }

  /* Animating different wave layers at varying speeds */
  .wave-parallax > use:nth-child(1) {
    animation-delay: -2s; /* Delayed by 2 seconds */
    animation-duration: 7s; /* Animation duration is 7 seconds */
  }
  .wave-parallax > use:nth-child(2) {
    animation-delay: -3s; /* Delayed by 3 seconds */
    animation-duration: 10s; /* Animation duration is 10 seconds */
  }
  .wave-parallax > use:nth-child(3) {
    animation-delay: -4s; /* Delayed by 4 seconds */
    animation-duration: 13s; /* Animation duration is 13 seconds */
  }
  .wave-parallax > use:nth-child(4) {
    animation-delay: -5s; /* Delayed by 5 seconds */
    animation-duration: 20s; /* Animation duration is 20 seconds */
  }

  /* Animation for the wave movement */
  @keyframes move-forever {
    0% {
      transform: translate3d(-90px, 0, 0); /* Starting position */
    }
    100% {
      transform: translate3d(85px, 0, 0); /* Ending position */
    }
  }

  /* Animation for the background gradient */
  @keyframes gradient {
    0% {
      background-position: 0% 50%; /* Starting position of the gradient */
    }
    50% {
      background-position: 100% 50%; /* Midway position of the gradient */
    }
    100% {
      background-position: 0% 50%; /* Ending position of the gradient */
    }
  }
</style>

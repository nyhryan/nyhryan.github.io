---
import type { ImageMetadata } from "astro";
import { Font } from "astro:assets";
import { SEO } from "astro-seo";
import FallbackImage from "../../assets/fallback.jpg";
import { SITE_TITLE, SITE_DESCRIPTION, SITE_CONFIG } from "@consts";
import LoadTheme from "@components/common/LoadTheme.astro";
import PhotoSwipe from "@components/common/PhotoSwipe.astro";

type Props = {
  title?: string;
  description?: string;
  image?: ImageMetadata;
  noindex?: boolean;
};

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const {
  description = SITE_DESCRIPTION,
  image = FallbackImage,
  noindex = false,
} = Astro.props;

const title = `${Astro.props.title}::${SITE_TITLE}`;
const isArticle = Astro.url.pathname.split("/")[1] === "blog";
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1.0" />
<link rel="icon" type="image/png" href="/favicon.png" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
  rel="alternate"
  type="application/rss+xml"
  title={title}
  href={new URL("rss.xml", Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<Font cssVariable="--font-chiron-go-round-tc" preload />
<Font cssVariable="--font-ibm-plex-sans-kr" />
<Font cssVariable="--font-cascadia-code" />

<SEO
  title={title}
  description={description}
  canonical={canonicalURL}
  openGraph={{
    basic: {
      title: title,
      type: "website",
      image: new URL(image.src, Astro.url).toString(),
      url: Astro.url,
    },
  }}
  twitter={{
    card: "summary_large_image",
    site: SITE_CONFIG.social.twitter,
    title: title,
    description: description,
    image: new URL(image.src, Astro.url),
    imageAlt: "Ataidev blog",
  }}
  noindex={noindex}
/>

<LoadTheme />
<PhotoSwipe />

---
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import { getCollection, render } from "astro:content";
import BaseBlogLayout from "@layouts/BaseBlogLayout.astro";
import PrevNextPostNav from "@components/common/PrevNextPostNav.astro";
import BaseHead from "@components/BaseHead.astro";
import BlogPostingStructuredData from "@components/structuredData/BlogPostingStructuredData.astro";

export const getStaticPaths = (async () => {
  return (await getCollection("blog"))
    .sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf())
    .map((post, i, arr) => {
      if (i > 0 || i < arr.length - 1) {
        return {
          params: { slug: post.id },
          props: { post, prev: arr[i - 1], next: arr[i + 1] },
        };
      } else if (i == 0) {
        return {
          params: { slug: post.id },
          props: { post, prev: null, next: arr[i + 1] },
        };
      } else {
        return {
          params: { slug: post.id },
          props: { post, prev: arr[i - 1], next: null },
        };
      }
    });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { post, prev, next } = Astro.props;
const { Content } = await render(post);

const updatedDate =
  post.data.updatedDate ?? post.data.pubDate;
---

<!doctype html>
<html lang={post.data.locale}>
  <head>
    <BaseHead title={post.data.title} description={post.data.description} />
    <BlogPostingStructuredData {...post.data} />
  </head>
  <body>
    <BaseBlogLayout>
      <div class="bg-ctp-base p-4 sm:p-6 rounded-(--card-radius)">
        <h1 class="text-4xl font-bold mb-2">{post.data.title}</h1>
        <div class="flex flex-col items-end gap-1 text-ctp-subtext0 text-sm/tight">
          <div>
            <span>Published: </span>
            <time datetime={post.data.pubDate.toISOString()}
              >{post.data.pubDate.toLocaleDateString()}</time
            >
          </div>
          <div>
            <span>Last update: </span>
            <time
              datetime={updatedDate.toISOString()}
              >{updatedDate.toLocaleDateString()}</time
            >
          </div>
        </div>
        <div class="prose-catppuccin">
          <Content />
        </div>
        <hr class="my-4 text-ctp-surface0"/>
        <PrevNextPostNav prev={prev} next={next} />
        <div class="giscus"></div>
      </div>
    </BaseBlogLayout>
  </body>
</html>

<script
  src="https://giscus.app/client.js"
  data-repo="nyhryan/nyhryan.github.io"
  data-repo-id="R_kgDOPpedIQ"
  data-category="General"
  data-category-id="DIC_kwDOPpedIc4CvCAo"
  data-mapping="pathname"
  data-strict="0"
  data-reactions-enabled="1"
  data-emit-metadata="1"
  data-input-position="top"
  data-theme="catppuccin_frappe"
  data-lang="en"
  crossorigin="anonymous"
  async></script>

---
import type { GetStaticPaths } from "astro";
import { type CollectionEntry, getCollection, render } from "astro:content";
import BaseBlogLayout from "@layouts/BaseBlogLayout.astro";
import PrevNextPostNav from "@components/PrevNextPostNav.astro";
import type {BlogPost} from "../../utils/types.ts";

interface Props {
  post: BlogPost;
  prev?: BlogPost;
  next?: BlogPost;
}

export const getStaticPaths = (async () => {
  return (await getCollection("blog"))
    .sort((a, b) => a.data.pubDate - b.data.pubDate)
    .map((post, i, arr) => {
      if (i > 0 || i < arr.length - 1) {
        return {
          params: { slug: post.id },
          props: { post, prev: arr[i - 1], next: arr[i + 1] }
        };
      }
      else if (i == 0) {
        return {
          params: { slug: post.id },
          props: { post, prev: null, next: arr[i + 1] }
        };
      }
      else {
        return {
          params: { slug: post.id },
          props: { post, prev: arr[i - 1], next: null }
        };
      }
    });
}) satisfies GetStaticPaths;

const { post, prev, next } = Astro.props;
const { Content } = await render(post);

---
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import { getCollection } from "astro:content";
import PostCardItem from "@components/common/PostCardItem.astro";
import type { BlogPost } from "@utils/types";
import PaginationNav from "@components/common/PaginationNav.astro";

import { sortPost } from "@utils/content";
import BaseBlogLayout from "@layouts/BaseBlogLayout.astro";

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = sortPost(await getCollection("blog"), "desc");
  const pathMap = new Map<string, Array<BlogPost>>();

  allPosts.forEach((post) => {
    const segments = post.id.split("/").slice(0, -1);
    let currentPath = "";
    segments.forEach((segment) => {
      currentPath = currentPath ? `${currentPath}/${segment}` : segment;
      if (!pathMap.has(currentPath)) {
        pathMap.set(currentPath, []);
      }
      pathMap.get(currentPath)!.push(post);
    });
  });

  return Array.from(pathMap.entries()).flatMap(([categoryPath, posts]) =>
    paginate(posts, {
      pageSize: 10,
      params: { path: categoryPath },
      props: {
        categoryName: categoryPath.split("/").pop() ?? "no-category",
        fullCategoryPath: categoryPath,
      },
    }),
  );
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { page, categoryName, fullCategoryPath } = Astro.props;
---

<BaseBlogLayout noindex={true} currentCategory={categoryName}>
  <div slot="main-content">
    <!-- Category title -->
    <h1 class="mb-4 text-center font-chiron text-4xl font-black">
      Showing category:
      <span class="font-bold underline">`{fullCategoryPath}`</span>
    </h1>
    <!-- Category post cards -->
    <div class="mb-4 flex flex-col gap-y-4">
      {page.data.map((post) => <PostCardItem {...post} />)}
    </div>
  </div>
  
  <div slot="after-main">
    <PaginationNav pages={page} />
  </div>
</BaseBlogLayout>

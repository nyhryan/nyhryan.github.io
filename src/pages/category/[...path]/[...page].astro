---
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import { getCollection } from "astro:content";
import PostCardItem from "@components/common/PostCardItem.astro";
import BaseBlogLayout from "@layouts/BaseBlogLayout.astro";
import type { BlogPost } from "../../../utils/types";
import BaseHead from "@components/BaseHead.astro";
import WebSiteStructuredData from "@components/structuredData/WebSiteStructuredData.astro";

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = (await getCollection("blog")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );
  const pathMap = new Map<string, Array<BlogPost>>();

  allPosts.forEach((post) => {
    const segments = post.id.split("/").slice(0, -1);
    let currentPath = "";
    segments.forEach((segment) => {
      currentPath = currentPath ? `${currentPath}/${segment}` : segment;
      if (!pathMap.has(currentPath)) {
        pathMap.set(currentPath, []);
      }
      pathMap.get(currentPath)!.push(post);
    });
  });

  return Array.from(pathMap.entries()).flatMap(([categoryPath, posts]) =>
    paginate(posts, {
      pageSize: 10,
      params: { path: categoryPath },
      props: {
        categoryName: categoryPath.split("/").pop(),
        fullCategoryPath: categoryPath,
      },
    }),
  );
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { page, categoryName, fullCategoryPath } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead noindex={true}/>
    <WebSiteStructuredData />
  </head>
  <body>
    <BaseBlogLayout currentCategory={categoryName} pages={page}>
      <h3 class="text-4xl font-chiron font-black text-center">
        Showing category:
        <span class="font-bold underline">`{fullCategoryPath}`</span>
      </h3>
      {page.data.map((post) => <PostCardItem {...post} />)}
    </BaseBlogLayout>
  </body>
</html>
